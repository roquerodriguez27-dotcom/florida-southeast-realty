# Florida Southeast Realty — environment variables
# Copy to .env.local and fill in only what you've actually configured.
# Nothing here is required for `npm run dev` — the site runs fully on
# sample data and honestly reports unconfigured features until you do.

# --- Lead delivery (app/api/lead/route.ts) ---
# Set ONE of the following two options to make lead forms actually send:

# Option A: forward every lead as JSON to your CRM's inbound webhook
# (HubSpot, Follow Up Boss, a Zapier/Make catch hook, etc).
LEAD_WEBHOOK_URL=

# Option B: send a transactional email via Resend (https://resend.com).
RESEND_API_KEY=
RESEND_TO_EMAIL=
RESEND_FROM_EMAIL=

# --- IDX / MLS feed (lib/idx.ts) ---
# Populate once you've selected a provider (RESO Web API, IDX Broker, or
# Spark Platform/FlexMLS) and wired fetchLiveListings() to call it.
IDX_PROVIDER_BASE_URL=
IDX_PROVIDER_API_KEY=
IDX_MLS_DISCLAIMER_TEXT=

# --- Analytics ---
# No analytics provider is wired into this project. If you add one
# (GA4, Plausible, etc.), store its ID here and reference it from
# app/layout.tsx.
NEXT_PUBLIC_ANALYTICS_ID=

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://www.floridasoutheastrealty.com
